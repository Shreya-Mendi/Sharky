# --- Backend (Railway: add these as environment variables in the backend service) ---
ANTHROPIC_API_KEY=          # Required — powers Research Copilot and RAG analysis
NEWSAPI_KEY=                # Optional — live market alerts; engines degrade gracefully without it

# --- Frontend (Railway: add these as environment variables in the frontend service) ---
NEXT_PUBLIC_API_URL=        # Required in production — set to your Railway backend URL
                            # e.g. https://sharky-backend-production.up.railway.app

# --- Removed (no longer needed) ---
# OPENAI_API_KEY            — RAG now uses local sentence-transformers, not OpenAI embeddings
# PINECONE_API_KEY          — vector store is now in-process, no external DB
# PINECONE_INDEX_NAME       — same as above
# DATABASE_URL              — no PostgreSQL dependency
